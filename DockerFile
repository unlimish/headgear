FROM node:20-slim

WORKDIR /app

# Install build dependencies if needed, though for discord.js they are usually not required
# Copy package manifests
COPY package.json pnpm-lock.yaml* yarn.lock* package-lock.json* ./

# Install production dependencies
RUN npm install --omit=dev

# Copy local code (instead of cloning from github to include local changes)
COPY . .

# Ensure data directory exists
RUN mkdir -p data

ENTRYPOINT ["node", "index.js"]
